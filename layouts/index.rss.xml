{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ .Site.Title }}</title>
    <link>{{ .Site.BaseURL }}</link>
    <description>Writing on security, cryptography, and whatever else is on my mind.</description>
    <generator>Hugo</generator>
    <language>{{ site.Language.LanguageCode }}</language>
    <lastBuildDate>{{ (index (where .Site.RegularPages "Section" "posts").ByDate.Reverse 0).Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    <atom:link href="{{ .Site.BaseURL }}index.xml" rel="self" type="application/rss+xml" />
    {{- range (where .Site.RegularPages "Section" "posts").ByDate.Reverse }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      <description>{{ .Content | html }}</description>
    </item>
    {{- end }}
  </channel>
</rss>
